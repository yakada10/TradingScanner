# Stock Fitness Agent — Environment Variables
# Copy to .env for local development. NEVER commit .env.

# ── Security (REQUIRED in production) ────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-insecure-key-change-before-deploy

# ── Admin account (auto-created on first startup if no users exist) ──
# Change these before deploying — especially ADMIN_PASSWORD.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ── Signup control ────────────────────────────────────────────────────
# false = only the auto-created admin can log in (recommended for personal use)
# true  = anyone can register a new account
ALLOW_SIGNUP=false

# ── Server ───────────────────────────────────────────────────────────
PORT=5000
ENVIRONMENT=development        # development | production
LOG_LEVEL=INFO

# ── Worker ───────────────────────────────────────────────────────────
RUN_WORKER_INLINE=true
WORKER_POLL_INTERVAL=3
SCAN_HISTORY_DAYS=30

# ── Database ─────────────────────────────────────────────────────────
# LOCAL:  blank → SQLite at ./data/stock_fitness.db
# PROD:   set automatically by Render fromDatabase wiring
DATABASE_URL=

# ── Storage ──────────────────────────────────────────────────────────
# LOCAL:  blank → ./data/
# PROD:   /data (Render persistent disk on worker)
DATA_DIR=

# ── Market Data / News API Keys (optional) ───────────────────────────
FINNHUB_API_KEY=
FMP_API_KEY=
