# Stock Fitness Agent — Environment Variables
# Copy this file to .env for local development.
# NEVER commit .env to version control.
#
# LOCAL DEVELOPMENT
#   RUN_WORKER_INLINE=true  (worker runs as thread inside web process)
#   DATABASE_URL blank      (uses SQLite at ./data/stock_fitness.db)
#
# PRODUCTION (Render)
#   RUN_WORKER_INLINE=false (web service only; separate worker process)
#   DATABASE_URL=<postgres> (set automatically by render.yaml fromDatabase)

# ── Server ───────────────────────────────────────────────────────────
PORT=5000
ENVIRONMENT=development        # development | production
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR

# ── Worker ───────────────────────────────────────────────────────────
# LOCAL: true  — worker runs as a background thread inside the web process
# PROD:  false — worker runs as a separate Render background worker service
RUN_WORKER_INLINE=true

# How often the worker polls the DB for new jobs (seconds)
WORKER_POLL_INTERVAL=3

# ── Database ─────────────────────────────────────────────────────────
# LOCAL:  Leave blank → defaults to SQLite at ./data/stock_fitness.db
# PROD:   Set automatically by Render via the fromDatabase wiring in render.yaml
#         If overriding manually: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# ── Storage ──────────────────────────────────────────────────────────
# Directory for SQLite DB file (local) and yfinance price/fundamentals cache.
# LOCAL:  Leave blank → defaults to ./data/ in the project root
# PROD:   Set to /data (Render persistent disk mounted on the worker service)
DATA_DIR=

# ── Market Data / News API Keys ──────────────────────────────────────
# Optional — the app works with free yfinance without these.
# Set in Render dashboard (never commit real values here).

# Finnhub — richer news and earnings calendar (free tier available)
# https://finnhub.io
FINNHUB_API_KEY=

# Financial Modeling Prep — alternative fundamentals source (free tier available)
# https://financialmodelingprep.com
FMP_API_KEY=
